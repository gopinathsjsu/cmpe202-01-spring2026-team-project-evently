set dotenv-load
set export

# List available recipes
default:
    @just --list

# Check required environment variables
check-env:
    @if [ -z "${DB_USERNAME:-}" ]; then \
        echo "Error: DB_USERNAME is not set"; \
        echo "Please create .env from .env.example: cp .env.example .env"; \
        exit 1; \
    fi
    @if [ -z "${DB_PASSWORD:-}" ]; then \
        echo "Error: DB_PASSWORD is not set"; \
        echo "Please create .env from .env.example: cp .env.example .env"; \
        exit 1; \
    fi

# Start MongoDB and Redis, wait for them to be ready, and seed sample data
db: _services
    @echo "MongoDB and Redis are ready. Seeding data..."
    uv run python -m backend.seed --force

# Start MongoDB/Redis (with seed), then run the backend and notification worker
dev: db
    #!/usr/bin/env bash
    set -euo pipefail

    pids=()

    cleanup() {
        trap - EXIT INT TERM
        if ((${#pids[@]})); then
            kill "${pids[@]}" 2>/dev/null || true
            wait "${pids[@]}" 2>/dev/null || true
        fi
    }

    trap cleanup EXIT
    trap 'cleanup; exit 130' INT
    trap 'cleanup; exit 143' TERM

    echo "Starting notification worker..."
    uv run notif-worker &
    pids+=("$!")

    echo "Starting backend..."
    uv run backend &
    pids+=("$!")

    set +e
    status=0
    while :; do
        for pid in "${pids[@]}"; do
            if ! kill -0 "$pid" 2>/dev/null; then
                wait "$pid"
                status=$?
                break 2
            fi
        done
        sleep 1
    done
    set -e

    exit "$status"

# Start MongoDB/Redis, then run only the notification worker
worker: _services
    @echo "Starting notification worker..."
    uv run notif-worker

# Stop MongoDB and Redis
db-stop:
    docker compose down
    @docker compose -f ../docker-compose.yml stop mongodb redis 2>/dev/null || true

# View MongoDB logs
db-logs:
    docker compose logs -f mongodb

# Restart everything
restart: db-stop dev

# Regenerate compact sample event image assets used by seed data
seed-images:
    cd .. && node scripts/generate_seed_event_images.mjs

# Re-seed the database (drops existing data)
seed: check-env
    uv run seed --force

# ── Helpers ────────────────────────────────────────────────────────────

[private]
_services: check-env _stop-stack-db
    docker compose up -d mongodb redis
    @echo "Waiting for MongoDB to accept connections..."
    @until docker compose exec mongodb mongosh --quiet \
        -u "${DB_USERNAME}" -p "${DB_PASSWORD}" \
        --eval "db.runCommand({ ping: 1 })" > /dev/null 2>&1; do \
        sleep 1; \
    done
    @echo "Waiting for Redis to accept connections..."
    @until docker compose exec redis redis-cli ping > /dev/null 2>&1; do \
        sleep 1; \
    done
_stop-stack-db:
    @docker compose -f ../docker-compose.yml stop mongodb redis 2>/dev/null || true
