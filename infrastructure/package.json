{
  "name": "evently-infrastructure",
  "version": "1.0.0",
  "description": "Evently AWS infrastructure (VPC, ALB, ASG, S3, DB) defined with AWS CDK in TypeScript",
  "bin": {
    "evently-infra": "bin/evently.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy",
    "diff": "cdk diff",
    "destroy": "cdk destroy"
  },
  "devDependencies": {
    "@types/node": "20.10.0",
    "aws-cdk": "2.1118.0",
    "source-map-support": "^0.5.21",
    "typescript": "~5.6.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.248.0",
    "constructs": "^10.4.2"
  }
}
